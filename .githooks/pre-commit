#!/bin/sh
# Blocks commits whose staged changes contain "Starfinder" or "Charakterbogen"
# (case-insensitive, any combination). Repo is public; rules content is
# purchased/copyrighted, so these words must never appear in committed text.
#
# Enabled via: git config core.hooksPath .githooks

forbidden='Starfinder|Charakterbogen'
hits=$(git diff --cached -U0 --no-color -- . ':!.githooks/pre-commit' ':!.github/workflows/deploy.yml' \
  | grep -E '^\+' | grep -viE '^\+\+\+' | grep -iE "$forbidden")

if [ -n "$hits" ]; then
  echo "❌ Commit blocked: staged changes contain a forbidden word (Starfinder/Charakterbogen)."
  echo "$hits"
  echo
  echo "Use a neutral term instead (e.g. \"SF1e\", \"Bogen\"). See AGENTS.md."
  exit 1
fi
